# =============================================================================
# OldDungeons game-server (fork Tibia74-JS-Engine + Supabase Auth)
# Copie para .env no EC2 antes de iniciar o PM2.
# =============================================================================

# Supabase (mesmo projeto do site)
SUPABASE_URL=https://hewxrvrqbzkggajgojid.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_SERVICE_ROLE
SUPABASE_JWKS_URL=https://hewxrvrqbzkggajgojid.supabase.co/auth/v1/.well-known/jwks.json

# Servidor WS binário do engine
GAME_HOST=0.0.0.0
GAME_PORT=2222

# Origem permitida (CORS/handshake)
ALLOWED_ORIGIN=https://retro-idle-forge.lovable.app

# Ambiente
NODE_ENV=production

# =============================================================================
# Frontend (site Lovable): definir em .env do site
# =============================================================================
# VITE_GAME_WS_URL     = host:porta do game-server (ex.: game.exemplo.com:2222)
# VITE_GAME_ASSETS_URL = URL absoluta do game-server servindo Tibia.spr/.dat
#                        (padrão: mesmo host de VITE_GAME_WS_URL)
