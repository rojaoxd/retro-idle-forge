# === Supabase ===
# Vem de: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://hewxrvrqbzkggajgojid.supabase.co
# NUNCA exponha essa chave no frontend. Só o servidor da AWS a possui.
SUPABASE_SERVICE_ROLE_KEY=coloque_o_service_role_key_aqui

# === Colyseus ===
PORT=2567

# === Loop de persistência ===
# Intervalo (ms) para gravar em lote posição/HP dos players no Supabase.
PERSIST_INTERVAL_MS=5000
# Intervalo (ms) para gravar logs acumulados em server_logs.
LOG_FLUSH_INTERVAL_MS=10000
